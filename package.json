{
  "name": "candt-nextjs-template",
  "packageManager": "yarn@4.9.2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --no-warn-ignored",
    "lint:fix": "eslint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "new:component": "yarn plop --plopfile ./.plop/plopfile.mjs",
    "dependency-graph": "npx skott --displayMode=webapp --trackThirdPartyDependencies --trackBuiltinDependencies --cwd=./src",
    "prepare": "husky",
    "typecheck": "next build --experimental-build-mode compile && tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@t3-oss/env-nextjs": "^0.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jiti": "^1.21.7",
    "next": "16.0.9",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@jest/globals": "^30.2.0",
    "@next/eslint-plugin-next": "16.0.10",
    "@storybook/addon-a11y": "^10.1.10",
    "@storybook/addon-designs": "^11.1.0",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/addon-links": "^10.1.10",
    "@storybook/builder-vite": "^10.1.10",
    "@storybook/nextjs-vite": "^10.1.10",
    "@total-typescript/ts-reset": "^0.5.1",
    "@tsconfig/next": "^2.0.5",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-security": "^3.0.0",
    "@types/node": "^20.14.2",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "autoprefixer": "^10.4.19",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.0.10",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-jest": "^29.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-barrel-files": "^1.2.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-hooks-extra": "^2.3.13",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.7.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-storybook": "^10.1.10",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-testing-library": "^7.15.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^16.3.0",
    "husky": "^9.0.11",
    "lint-staged": "^16.1.5",
    "msw": "^2.12.7",
    "msw-storybook-addon": "^2.0.6",
    "plop": "^4.0.1",
    "postcss": "^8",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "0.7.2",
    "storybook": "^10.1.10",
    "tailwindcss": "^3.4.4",
    "tsc": "^2.0.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "webpack": "^5.91.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,yml,md,css,graphql}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --max-warnings 0 --no-warn-ignored"
    ]
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  },
  "msw": {
    "workerDirectory": [
      "public-storybook"
    ]
  }
}
